APP_ENV=development
APP_BASE_URL=http://localhost:8000
APP_BASE_PATH=
SESSION_NAME=panicmic_sid
CSRF_SECRET=replace-with-a-long-random-secret
TRUST_PROXY=false
ALLOWED_HOSTS=localhost,127.0.0.1,panicmic.com,*.panicmic.com,panicmic.local,bluebird.local,neon.local,signup.localhost

# Signup hosts.
#   SIGNUP_ROOT_DOMAIN — the apex under which new tenants are provisioned.
#     A signup of slug "lucky" creates the tenant at lucky.<SIGNUP_ROOT_DOMAIN>.
#   SIGNUP_HOST — the dedicated hostname that serves the venue-signup UI.
#     When the incoming Host header matches SIGNUP_HOST, no tenant lookup
#     happens and "/" renders the signup landing page. All tenant routes
#     are blocked on this host.
SIGNUP_ROOT_DOMAIN=panicmic.com
SIGNUP_HOST=signup.panicmic.com

# Super-admin host.
#   SUPER_HOST — the dedicated hostname for the global admin UI
#     (e.g. admin.panicmic.com). When the incoming Host header matches
#     SUPER_HOST, no tenant lookup happens and only /super and /api/super
#     routes are served. Tenant-scoped paths return 404 from this host.
#     Leave blank to keep the legacy behavior of serving /super from any
#     allowed host.
SUPER_HOST=admin.panicmic.com

SUPER_DB_HOST=127.0.0.1
SUPER_DB_PORT=3306
SUPER_DB_USER=root
SUPER_DB_PASSWORD=
SUPER_DB_NAME=panicmic_super

TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_DB_USER=root
TENANT_DB_PASSWORD=
TENANT_DB_PREFIX=panicmic_

# Provisioning user — needs CREATE/ALTER/DROP on panicmic_super and panicmic_*
# schemas. Used by scripts/migrate.php and tenant provisioning (CREATE
# DATABASE + per-tenant schema migrations). Falls back to SUPER_DB_* if
# unset. Recommended grant pattern:
#   GRANT ALL PRIVILEGES ON `panicmic_super`.* TO '<user>'@'127.0.0.1';
#   GRANT ALL PRIVILEGES ON `panicmic_%`.*     TO '<user>'@'127.0.0.1';
PROVISION_DB_HOST=127.0.0.1
PROVISION_DB_PORT=3306
PROVISION_DB_USER=
PROVISION_DB_PASSWORD=

# Mail delivery.
# - log (default): writes messages to storage/mail.log; nothing leaves the box.
# - exim / sendmail: pipes RFC822 to the local MTA (default /usr/sbin/exim -t -i).
# - postmark: HTTP API via POSTMARK_TOKEN (kept for hosted setups).
MAIL_DRIVER=log
MAIL_FROM=no-reply@panicmic.com
MAIL_FROM_NAME=Panic Mic
MAIL_SENDMAIL_PATH=/usr/sbin/exim
POSTMARK_TOKEN=

# Errors and structured events are written to storage/logs/errors-YYYY-MM-DD.log
# (one file per day, JSON lines). No third-party error tracker is wired in.

YOUTUBE_API_KEY=
YOUTUBE_AUTO_ATTACH=true

KARAFUN_API_TOKEN=
KARAFUN_API_BASE_URL=https://business.karafun.com/api
STINGRAY_API_BASE_URL=
STINGRAY_API_CLIENT_ID=
STINGRAY_API_CLIENT_SECRET=
